{
  "name": "terminal-error-sound",
  "displayName": "Terminal Error Sound",
  "description": "Plays a sound whenever a command fails in the terminal.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Terminal Error Sound",
      "properties": {
        "terminalErrorSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable all terminal error sounds."
        },
        "terminalErrorSound.playOnDiagnosticsError": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when new diagnostic errors (red squigglies) appear in the editor."
        },
        "terminalErrorSound.playOnTaskFailure": {
          "type": "boolean",
          "default": true,
          "description": "Play sound when a terminal process exits with a non-zero code."
        },
        "terminalErrorSound.playOnDebugFailure": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when a debug session fails."
        },
        "terminalErrorSound.cooldownMs": {
          "type": "number",
          "default": 1000,
          "description": "Minimum time (in milliseconds) between sounds to prevent overlapping playback."
        }
      }
    },
    "commands": [
      {
        "command": "terminalErrorSound.enable",
        "title": "Enable Terminal Error Sound"
      },
      {
        "command": "terminalErrorSound.disable",
        "title": "Disable Terminal Error Sound"
      },
      {
        "command": "terminalErrorSound.testSound",
        "title": "Test Terminal Error Sound"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {}
}